{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    "helpers:pinGitHubActionDigests",
    "customManagers:githubActionsVersions",
    "customManagers:dockerfileVersions"
  ],
  "automerge": true,
  "automergeType": "branch",
  "lockFileMaintenance": {
    "enabled": true
  },
  "minimumReleaseAge": "1 day"
}
